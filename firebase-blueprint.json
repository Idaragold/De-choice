{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user profile information, including their role and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email"]
    },
    "orders": {
      "title": "Order",
      "description": "Stores orders placed by users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who placed the order." },
        "items": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "quantity": { "type": "integer" }, "price": { "type": "number" } } }, "description": "The items in the order." },
        "status": { "type": "string", "enum": ["pending", "processing", "out-for-delivery", "completed", "cancelled"], "description": "The status of the order." },
        "total": { "type": "number", "description": "The total cost of the order." },
        "deliveryAddress": { "type": "string", "description": "The delivery address for the order." },
        "paymentMethod": { "type": "string", "enum": ["transfer", "pos", "cash"], "description": "The payment method used." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed." }
      },
      "required": ["uid", "items", "status", "total", "createdAt"]
    },
    "reviews": {
      "title": "Review",
      "description": "Stores user reviews for food and service.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who wrote the review." },
        "displayName": { "type": "string", "description": "The name of the reviewer." },
        "photoURL": { "type": "string", "description": "The photo of the reviewer." },
        "rating": { "type": "integer", "description": "The star rating (1-5)." },
        "comment": { "type": "string", "description": "The review text." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the review was written." }
      },
      "required": ["uid", "rating", "comment", "createdAt"]
    },
    "feedback": {
      "title": "Feedback",
      "description": "Stores general feedback from users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who provided feedback." },
        "email": { "type": "string", "format": "email", "description": "The user's email." },
        "message": { "type": "string", "description": "The feedback message." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the feedback was sent." }
      },
      "required": ["uid", "message", "createdAt"]
    },
    "promotions": {
      "title": "Promotion",
      "description": "Stores promotional images and videos generated by AI.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who created the promotion." },
        "type": { "type": "string", "enum": ["image", "video"], "description": "The type of promotion." },
        "url": { "type": "string", "description": "The URL of the generated asset." },
        "prompt": { "type": "string", "description": "The prompt used to generate the asset." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the promotion was created." }
      },
      "required": ["uid", "type", "url", "prompt", "createdAt"]
    },
    "voiceCallUsage": {
      "title": "Voice Call Usage",
      "description": "Tracks the daily voice call duration for each user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user." },
        "date": { "type": "string", "description": "The date in YYYY-MM-DD format." },
        "durationSeconds": { "type": "number", "description": "Total duration in seconds for the day." },
        "lastUpdatedAt": { "type": "string", "format": "date-time", "description": "When the usage was last updated." }
      },
      "required": ["uid", "date", "durationSeconds", "lastUpdatedAt"]
    },
    "knowledge": {
      "title": "AI Knowledge Base",
      "description": "Stores custom knowledge and rules for the AI assistant.",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "The knowledge content or rule." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the knowledge was added." }
      },
      "required": ["content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Collection of user profiles."
    },
    "/orders/{orderId}": {
      "schema": "orders",
      "description": "Collection of user orders."
    },
    "/reviews/{reviewId}": {
      "schema": "reviews",
      "description": "Collection of user reviews."
    },
    "/feedback/{feedbackId}": {
      "schema": "feedback",
      "description": "Collection of user feedback."
    },
    "/promotions/{promoId}": {
      "schema": "promotions",
      "description": "Collection of AI-generated promotions."
    },
    "/voiceCallUsage/{usageId}": {
      "schema": "voiceCallUsage",
      "description": "Collection of daily voice call usage tracking."
    },
    "/knowledge/{knowledgeId}": {
      "schema": "knowledge",
      "description": "Collection of custom AI knowledge entries."
    }
  }
}
